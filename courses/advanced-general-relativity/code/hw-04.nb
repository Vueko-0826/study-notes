    RowBox[{
     SuperscriptBox["a", "2"], " ", "\[CapitalDelta]", " ", 
     SuperscriptBox[
      RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"]}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"\[CapitalDelta]", "=", 
   RowBox[{
    SuperscriptBox["r", "2"], "+", 
