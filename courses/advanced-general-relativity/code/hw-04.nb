Cell[BoxData[{
 RowBox[{
  RowBox[{"\[Rho]", "=", 
   RowBox[{"Sqrt", "[", 
    RowBox[{
     SuperscriptBox["r", "2"], "+", 
     RowBox[{
      SuperscriptBox["a", "2"], " ", 
      SuperscriptBox[
       RowBox[{"Cos", "[", "\[Theta]", "]"}], "2"]}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"\[CapitalSigma]", "=", 
   RowBox[{
    SuperscriptBox[
     RowBox[{"(", 
