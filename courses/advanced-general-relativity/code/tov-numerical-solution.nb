Cell[BoxData[{
 RowBox[{"NDSolve", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       SuperscriptBox["m", "\[Prime]",
        MultilineFunction->None], "[", "r", "]"}], "\[Equal]", 
      RowBox[{"4", " ", "\[Pi]", " ", 
       SuperscriptBox["r", "2"], " ", 
       SqrtBox[
        RowBox[{"P", "[", "r", "]"}]]}]}], ",", 
     RowBox[{
      RowBox[{
       SuperscriptBox["P", "\[Prime]",
        MultilineFunction->None], "[", "r", "]"}], "\[Equal]", 
      RowBox[{"-", 
       FractionBox[
        RowBox[{" ", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            SqrtBox[
             RowBox[{"P", "[", "r", "]"}]], "+", 
            RowBox[{"P", "[", "r", "]"}]}], ")"}], " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"m", "[", "r", "]"}], "+", 
            RowBox[{"4", " ", "\[Pi]", " ", 
             SuperscriptBox["r", "3"], " ", 
             RowBox[{"P", "[", "r", "]"}]}]}], ")"}]}]}], 
        RowBox[{"r", " ", 
         RowBox[{"(", 
          RowBox[{"r", "-", 
           RowBox[{"2", " ", 
            RowBox[{"m", "[", "r", "]"}]}]}], ")"}]}]]}]}], ",", 
     RowBox[{
      RowBox[{"m", "[", "0.0001`", "]"}], "\[Equal]", "0"}], ",", 
     RowBox[{
      RowBox[{"P", "[", "0.0001`", "]"}], "\[Equal]", "1"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"m", ",", "P"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"r", ",", "0.0001`", ",", "1"}], "}"}]}], 
