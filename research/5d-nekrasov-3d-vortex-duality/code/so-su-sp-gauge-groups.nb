Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"AllYD", "[", "dim_", "]"}], "[", "totalboxes_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "P", ",", "PartitionSubsetQ", ",", "AddLayerPartition", ",", 
       "FromIntegerPartition", ",", "kPartitions", ",", "length", ",", 
       "basis", ",", "$$x", ",", "coord"}], "}"}], ",", 
     RowBox[{
      RowBox[{"P", "=", 
       RowBox[{"Symbol", "[", "\"\<P\>\"", "]"}]}], ";", 
      RowBox[{
       RowBox[{"PartitionSubsetQ", "[", 
        RowBox[{"All", ",", "a_"}], "]"}], ":=", "True"}], ";", "\n", 
      RowBox[{
       RowBox[{"PartitionSubsetQ", "[", 
        RowBox[{"A_Integer", ",", "a_Integer"}], "]"}], ":=", 
       RowBox[{"A", ">=", "a"}]}], ";", "\n", 
      RowBox[{
       RowBox[{"PartitionSubsetQ", "[", 
        RowBox[{"A_P", ",", "a_P"}], "]"}], ":=", 
       RowBox[{"And", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Length", "@", "a"}], "<=", 
          RowBox[{"Length", "@", "A"}]}], ",", 
         RowBox[{"And", "@@", 
          RowBox[{"Thread", "[", 
           RowBox[{"PartitionSubsetQ", "[", 
            RowBox[{
             RowBox[{"List", "@@", 
              RowBox[{"A", "[", 
               RowBox[{"[", 
                RowBox[{";;", 
                 RowBox[{"Length", "[", "a", "]"}]}], "]"}], "]"}]}], ",", 
             RowBox[{"List", "@@", "a"}]}], "]"}], "]"}]}]}], "]"}]}], ";", 
      RowBox[{
       RowBox[{"AddLayerPartition", "[", 
        RowBox[{"ppArray_", ",", "ipartitions_"}], "]"}], ":=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"ip", "->", 
          RowBox[{"Flatten", "@", 
           RowBox[{"Table", "[", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"Append", "[", 
                RowBox[{"#", ",", "ip"}], "]"}], "&"}], "/@", "arr"}], ",", 
             RowBox[{"{", 
              RowBox[{"arr", ",", 
               RowBox[{
                RowBox[{"Select", "[", 
                 RowBox[{"ppArray", ",", 
                  RowBox[{
                   RowBox[{"PartitionSubsetQ", "[", 
                    RowBox[{
                    RowBox[{"#", "[", 
                    RowBox[{"[", "1", "]"}], "]"}], ",", "ip"}], "]"}], 
                   "&"}]}], "]"}], "[", 
                RowBox[{"[", 
                 RowBox[{"All", ",", "2"}], "]"}], "]"}]}], "}"}]}], 
            "]"}]}]}], ",", 
         RowBox[{"{", 
          RowBox[{"ip", ",", "ipartitions"}], "}"}]}], "]"}]}], ";", "\n", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"FromIntegerPartition", "[", 
        RowBox[{"ipartition_List", ",", 
         RowBox[{"k_Integer", ":", "1"}]}], "]"}], ":=", 
       RowBox[{
        RowBox[{
         RowBox[{"Fold", "[", 
          RowBox[{"AddLayerPartition", ",", 
           RowBox[{"{", 
            RowBox[{"All", "->", 
             RowBox[{"{", 
              RowBox[{"P", "[", "]"}], "}"}]}], "}"}], ",", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{
              RowBox[{"kPartitions", "[", 
               RowBox[{"#", ",", "k"}], "]"}], "&"}], "/@", "ipartition"}], 
            ")"}]}], "]"}], "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "2"}], "]"}], "]"}], "//", "Flatten"}]}], ";", 
      "\n", 
      RowBox[{
       RowBox[{"kPartitions", "[", "n_Integer", "]"}], ":=", 
       RowBox[{
        RowBox[{
         RowBox[{"P", "@@", "#"}], "&"}], "/@", 
        RowBox[{"IntegerPartitions", "[", "n", "]"}]}]}], ";", "\n", 
      RowBox[{
       RowBox[{"kPartitions", "[", 
        RowBox[{"n_Integer", ",", "1"}], "]"}], ":=", 
       RowBox[{"kPartitions", "[", "n", "]"}]}], ";", "\n", 
      RowBox[{
       RowBox[{"kPartitions", "[", 
        RowBox[{"n_Integer", ",", "k_Integer"}], "]"}], ":=", 
       RowBox[{"Flatten", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"FromIntegerPartition", "[", 
           RowBox[{"#", ",", 
            RowBox[{"k", "-", "1"}]}], "]"}], "&"}], "/@", 
         RowBox[{"IntegerPartitions", "[", "n", "]"}]}], "]"}]}], ";", 
      RowBox[{
       RowBox[{"length", "[", "list_List", "]"}], ":=", 
       RowBox[{"Length", "[", "list", "]"}]}], ";", 
      RowBox[{
       RowBox[{"length", "[", "integer_Integer", "]"}], ":=", "integer"}], 
      ";", 
      RowBox[{"basis", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"$$x", "[", "i", "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "dim"}], "}"}]}], "]"}]}], ";", 
      RowBox[{
       RowBox[{"coord", "[", "YD_", "]"}], ":=", 
       RowBox[{"Flatten", "[", 
        RowBox[{
         RowBox[{"Table", "[", 
          RowBox[{"basis", ",", 
           RowBox[{"Evaluate", "[", 
            RowBox[{"Sequence", "@@", 
             RowBox[{"Transpose", "[", 
              RowBox[{"{", 
               RowBox[{"basis", ",", 
                RowBox[{
                 RowBox[{"Prepend", "[", 
                  RowBox[{"length", "[", "YD", "]"}], "]"}], "@", 
                 RowBox[{"Quiet", "[", 
                  RowBox[{"Table", "[", 
                   RowBox[{
                    RowBox[{"length", "[", 
                    RowBox[{"YD", "\[LeftDoubleBracket]", 
                    RowBox[{"Sequence", "@@", 
                    RowBox[{"Table", "[", 
                    RowBox[{
                    RowBox[{"$$x", "[", "i", "]"}], ",", 
                    RowBox[{"{", 
                    RowBox[{"i", ",", "1", ",", "j"}], "}"}]}], "]"}]}], 
                    "\[RightDoubleBracket]"}], "]"}], ",", 
                    RowBox[{"{", 
                    RowBox[{"j", ",", "1", ",", 
                    RowBox[{"dim", "-", "1"}]}], "}"}]}], "]"}], "]"}]}]}], 
               "}"}], "]"}]}], "]"}]}], "]"}], ",", 
         RowBox[{"dim", "-", "1"}]}], "]"}]}], ";", 
      RowBox[{"coord", "/@", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"kPartitions", "[", 
          RowBox[{"totalboxes", ",", 
           RowBox[{"dim", "-", "1"}]}], "]"}], "/.", 
         RowBox[{"P", "->", "List"}]}], ")"}]}]}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"AllYD", "[", "1", "]"}], "[", "totalboxes_", "]"}], ":=", 
   RowBox[{"{", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"{", "i", "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "totalboxes"}], "}"}]}], "]"}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"AllYD", "[", "dim_", "]"}], "[", "0", "]"}], ":=", 
   RowBox[{"{", 
    RowBox[{"{", "}"}], "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"AllYDlist", "[", 
    RowBox[{"dim_", ",", "\[CapitalNu]_", ",", "k_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "differentpartition", "}"}], ",", 
     RowBox[{
      RowBox[{"differentpartition", "=", 
       RowBox[{"Flatten", "[", 
        RowBox[{
         RowBox[{"Permutations", "/@", 
          RowBox[{"Select", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"PadRight", "[", 
               RowBox[{"#", ",", "\[CapitalNu]"}], "]"}], "&"}], "/@", 
             RowBox[{"IntegerPartitions", "[", "k", "]"}]}], ",", 
            RowBox[{
             RowBox[{
              RowBox[{"Total", "[", "#", "]"}], "==", "k"}], "&"}]}], "]"}]}],
