Cell[BoxData[
 InterpretationBox[
  RowBox[{
   FractionBox[
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"-", 
       FractionBox[
        RowBox[{"\[ImaginaryI]", " ", "k", " ", "\[Pi]", " ", "z"}], 
        RowBox[{"2", "+", "k"}]]}]], " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"-", "1"}], "+", 
       SuperscriptBox["\[ExponentialE]", 
        FractionBox[
         RowBox[{"2", " ", "\[ImaginaryI]", " ", 
          RowBox[{"(", 
           RowBox[{"1", "+", "k"}], ")"}], " ", "\[Pi]", " ", "z"}], 
         RowBox[{"2", "+", "k"}]]]}], ")"}]}], 
    RowBox[{
     RowBox[{"-", "1"}], "+", 
     SuperscriptBox["\[ExponentialE]", 
      FractionBox[
       RowBox[{"2", " ", "\[ImaginaryI]", " ", "\[Pi]", " ", "z"}], 
       RowBox[{"2", "+", "k"}]]]}]], "+", 
   RowBox[{"4", " ", 
    RowBox[{"Csc", "[", 
     FractionBox[
      RowBox[{"\[Pi]", " ", "z"}], 
      RowBox[{"2", "+", "k"}]], "]"}], " ", 
    RowBox[{"Sin", "[", 
     RowBox[{"\[Pi]", " ", "z"}], "]"}], " ", 
