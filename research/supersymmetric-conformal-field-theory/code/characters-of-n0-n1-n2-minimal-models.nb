      RowBox[{
       RowBox[{"Zpartition", "[", 
        RowBox[{"q", ",", "k", ",", "z", ",", "20"}], "]"}], "-", 
       RowBox[{"Sum", "[", 
        RowBox[{
         RowBox[{"chRT", "[", 
          RowBox[{"i", ",", 
           RowBox[{"i", "+", "1"}], ",", "k", ",", "q", ",", "z", ",", "20"}],
           "]"}], ",", 
