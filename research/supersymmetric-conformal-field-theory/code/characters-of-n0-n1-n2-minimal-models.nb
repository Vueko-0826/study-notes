Cell[BoxData[{
 RowBox[{
  RowBox[{"Eta", "[", 
   RowBox[{"q_", ",", "v1_"}], "]"}], ":=", 
  RowBox[{
   SuperscriptBox["q", 
    RowBox[{"1", "/", "24"}]], " ", 
   RowBox[{
    UnderoverscriptBox["\[Product]", 
     RowBox[{"n", "=", "1"}], "v1"], 
    RowBox[{"(", 
     RowBox[{"1", "-", 
      SuperscriptBox["q", "n"]}], ")"}]}]}]}], "\n", 
 RowBox[{
  RowBox[{"CK", "[", 
   RowBox[{
   "r_", ",", "s_", ",", "p1_", ",", "p2_", ",", "v1_", ",", "v2_", ",", 
    "q_"}], "]"}], ":=", 
  RowBox[{
   UnderoverscriptBox["\[Sum]", 
    RowBox[{"n", "=", 
     RowBox[{"-", "v2"}]}], "v2"], 
   RowBox[{
    SuperscriptBox["q", 
     FractionBox[
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         RowBox[{"2", " ", "p1", " ", "p2", " ", "n"}], "+", 
         RowBox[{"p1", " ", "r"}], "-", 
         RowBox[{"p2", " ", "s"}]}], ")"}], "2"], 
      RowBox[{"4", " ", "p1", " ", "p2"}]]], "/", 
    RowBox[{"Eta", "[", 
     RowBox[{"q", ",", "v1"}], "]"}]}]}]}]}], "Input",
 CellChangeTimes->{{3.9459126758355665`*^9, 3.945912732100935*^9}, {
   3.945912839917557*^9, 3.9459130774820576`*^9}, {3.9459132223323345`*^9, 
